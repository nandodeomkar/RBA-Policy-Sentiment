# Anthropic API key for the LLM scoring component.
# Needed from implementation plan step 15 (first live LLM run); not before.
# Copy this file to `.env` and fill in your key. `.env` is gitignored.
ANTHROPIC_API_KEY=

# Optional: override which transformer model the ensemble runs. Must be a key in
# the registry (src/rba_scorer/score/transformer_models.py); defaults to the
# active model there. Changing it changes engine_version, so re-runs stay
# reproducible.
# RBA_TRANSFORMER_MODEL=fed-stance
